<Application x:Class="Tellma.Backdoor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Tellma.Backdoor.Converters">
    <Application.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>

        <!-- InverseBool for IsEnabled bindings -->
        <conv:InverseBoolConverter x:Key="InverseBool"/>

        <!-- NotNull to Bool for enabling panels -->
        <conv:NotNullToBoolConverter x:Key="NotNullToBool"/>
    </Application.Resources>
</Application>
